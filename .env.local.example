# ============================================================
# Novák Blanka — környezeti változók
# Másold ezt .env.local névvel és töltsd ki az értékeket
# ============================================================

# App URL
# Vercel-en automatikusan beállítódik, de helyi fejlesztésnél add meg:
NEXT_PUBLIC_BASE_URL=https://blankanovak.com

# ─── Vercel Blob ──────────────────────────────────────────────
# Vercel dashboardból: Storage → Blob → Connect Store → .env.local copy
BLOB_READ_WRITE_TOKEN=

# ─── Airtable ─────────────────────────────────────────────────
# Airtable account → Developer Hub → Personal access tokens
AIRTABLE_API_KEY=pat...
# A base URL-jéből: airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Táblanevek — PONTOSAN így kell írni, ahogyan az Airtable-ben szerepelnek:
AIRTABLE_WEBINARS_TABLE=Webinár események
AIRTABLE_SUBSCRIBERS_TABLE=Feliratkozók
AIRTABLE_COURSE_BUYERS_TABLE=Kurzus vásárlók
AIRTABLE_DIGITAL_BUYERS_TABLE=Digitális termék vásárlók
AIRTABLE_MENTORING_BUYERS_TABLE=Mentorprogram vásárlók
AIRTABLE_PRODUCTS_TABLE=Termékek
AIRTABLE_TESTIMONIALS_TABLE=Vélemények
AIRTABLE_COURSES_TABLE=Kurzusok

# ─── Systeme.io ───────────────────────────────────────────────
# Systeme.io → Settings → API Keys
SYSTEMIO_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Dashboard → Developers → Webhooks → endpoint secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID-k (Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_MENTORING_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_GROUP_MENTORING_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_STRATEGY_PRICE_ID=price_...
NEXT_PUBLIC_COURSE_CHECKOUT_URL=/penztar?priceId=price_...&type=course
NEXT_PUBLIC_CAL_STRATEGY_URL=https://cal.com/blankanovak/strategia
NEXT_PUBLIC_CAL_MENTORING_URL=https://cal.com/blankanovak/privat-havi

# ─── Számlázz.hu ─────────────────────────────────────────────
SZAMLAZZ_AGENT_KEY=

# ─── Resend ───────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
# Az a domain, ahonnan az emailek mennek (Resend-ben hitelesítve kell lennie)
RESEND_FROM_EMAIL=hello@blankanovak.com

# ─── Cal.com ──────────────────────────────────────────────────
# Cal.com → Settings → Developer → Webhooks → secret
CAL_WEBHOOK_SECRET=

# ─── Admin ────────────────────────────────────────────────────
# Minimum 32 karakter! Generálj egy hosszú véletlenszerű stringet:
# pl: openssl rand -base64 32
ADMIN_TOKEN=

# ─── Előfizetési oldal (/elofizetes) ─────────────────────────
SUBSCRIPTION_PAGE_PASSWORD=

# ─── Cron (opcionális extra biztonság) ────────────────────────
CRON_SECRET=
